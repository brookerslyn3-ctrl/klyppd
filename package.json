{
  "name": "klyppd",
  "version": "0.3.0",
  "description": "Medal-style clip manager for Linux — gpu-screen-recorder + Cloudflare R2.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "electron:dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:1420 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:start": "npm run build && electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.brookerslyn.klyppd",
    "productName": "klyppd",
    "linux": {
      "target": ["deb", "rpm", "AppImage"],
      "category": "Utility",
      "icon": "public/logo.png"
    },
    "files": [
      "build/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  }
}
